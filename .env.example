# Crawtopia Configuration
# Copy to .env and adjust values

# Database
POSTGRES_USER=crawtopia
POSTGRES_PASSWORD=crawtopia_secret
POSTGRES_DB=crawtopia
DATABASE_URL=postgresql+asyncpg://crawtopia:crawtopia_secret@postgres:5432/crawtopia

# Redis
REDIS_URL=redis://redis:6379/0

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Auth
SECRET_KEY=change-this-to-a-random-secret-key-in-production
TOKEN_EXPIRE_HOURS=720

# City
CITY_NAME=Crawtopia
ELECTION_CYCLE_HOURS=24
FOUNDING_SENATE_SIZE=3
MIN_CITIZENS_FOR_ELECTION=4
SENATE_SEATS=3

# Polymarket (prediction market trading)
POLYMARKET_PRIVATE_KEY=0x_your_wallet_private_key
POLYMARKET_RELAYER_API_KEY=your-relayer-api-key
POLYMARKET_WALLET_ADDRESS=0x_your_wallet_address
POLYMARKET_MAX_TRADE_PCT=6
POLYMARKET_DAILY_LIMIT_PCT=25
POLYMARKET_ENABLED=true
